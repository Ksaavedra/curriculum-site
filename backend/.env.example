PORT=3000
CORS_ORIGIN=http://localhost:4200

# Onde recebes mensagens do formulário (obrigatório para envio real)
CONTACT_MAIL_TO=

# --- Opção A: Resend (recomendado se o Gmail dá EAUTH 535) ---
# https://resend.com → API Keys (começa por re_)
RESEND_API_KEY=
# Opcional; testes: Currículo site <onboarding@resend.dev>
RESEND_FROM=

# --- Opção B: SMTP Gmail (palavra-passe de aplicação, 16 caracteres) ---
# https://support.google.com/accounts/answer/185833

# =========================
# GMAIL - OPÇÃO 1 (SSL)
# Porta 465 + secure=true
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# =========================
# GMAIL - OPÇÃO 2 (TLS)
# Porta 587 + secure=false
# =========================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
